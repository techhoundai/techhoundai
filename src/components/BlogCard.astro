---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
  readingTime?: string;
  headingLevel?: "h2" | "h3";
}

const { title, description, date, slug, tags, readingTime, headingLevel = "h3" } = Astro.props;
const Heading = headingLevel;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a href={`/blog/${slug}/`} class="card overflow-hidden group block hover:shadow-lg transition-all duration-300">
  <div class="p-6">
    <div class="flex items-center gap-3 text-xs text-secondary mb-3">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      {readingTime && <span>{readingTime}</span>}
    </div>
    <Heading class="text-lg font-heading font-semibold mb-2 group-hover:text-gold transition-colors">
      {title}
    </Heading>
    <p class="text-secondary text-sm leading-relaxed">{description}</p>
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-4">
        {tags.map((tag) => (
          <span class="text-xs px-2 py-1 rounded-full bg-gold/10 text-gold dark:bg-gold/20 font-medium">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
