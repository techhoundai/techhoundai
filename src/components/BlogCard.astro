---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  image?: string;
  tags?: string[];
  readingTime?: string;
}

const { title, description, date, slug, image, tags, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a href={`/blog/${slug}`} class="card overflow-hidden group block hover:shadow-lg transition-all duration-300">
  {image && (
    <div class="relative overflow-hidden aspect-video">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-6">
    <div class="flex items-center gap-3 text-xs text-secondary mb-3">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      {readingTime && <span>{readingTime}</span>}
    </div>
    <h3 class="text-lg font-heading font-semibold mb-2 group-hover:text-gold transition-colors">
      {title}
    </h3>
    <p class="text-secondary text-sm leading-relaxed">{description}</p>
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-4">
        {tags.map((tag) => (
          <span class="text-xs px-2 py-1 rounded-full bg-gold/10 text-gold dark:bg-gold/20 font-medium">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
