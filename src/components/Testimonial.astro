---
interface Props {
  quote: string;
  name: string;
  company: string;
}

const { quote, name, company } = Astro.props;
---

<blockquote class="card p-6 md:p-8">
  <svg class="w-8 h-8 text-gold/30 mb-4" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10H0z" />
  </svg>
  <p class="text-lg leading-relaxed mb-4 italic">"{quote}"</p>
  <footer>
    <p class="font-semibold">{name}</p>
    <p class="text-secondary text-sm">{company}</p>
  </footer>
</blockquote>
