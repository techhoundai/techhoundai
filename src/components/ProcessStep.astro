---
interface Props {
  number: number;
  title: string;
  description: string;
  isLast?: boolean;
}

const { number, title, description, isLast = false } = Astro.props;
---

<div class="flex gap-6">
  <div class="flex flex-col items-center">
    <div class="w-12 h-12 rounded-full bg-gold flex items-center justify-center text-[#0A0A0A] font-bold text-lg flex-shrink-0">
      {number}
    </div>
    {!isLast && (
      <div class="w-px h-full bg-gold/20 mt-2"></div>
    )}
  </div>
  <div class={`pb-12 ${isLast ? 'pb-0' : ''}`}>
    <h3 class="text-xl font-heading font-semibold mb-2">{title}</h3>
    <p class="text-secondary leading-relaxed">{description}</p>
  </div>
</div>
