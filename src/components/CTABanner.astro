---
interface Props {
  title?: string;
  subtitle?: string;
  buttonLabel?: string;
  buttonHref?: string;
}

const {
  title = "Ready to get started?",
  subtitle = "Let's talk about what you're building.",
  buttonLabel = "Schedule a Consultation",
  buttonHref = "/contact",
} = Astro.props;
---

<section class="border-t border-[#E8E4DC] dark:border-[#1E1E1E]">
  <div class="container-default px-4 py-10 sm:px-6 sm:py-12 lg:px-8 text-center">
    <h2 class="text-2xl sm:text-3xl font-heading font-bold mb-3">
      {title}
    </h2>
    <p class="text-base text-secondary mb-6 max-w-xl mx-auto">
      {subtitle}
    </p>
    <a
      href={buttonHref}
      class="btn-primary text-lg !px-8 !py-4"
    >
      {buttonLabel}
    </a>
  </div>
</section>
