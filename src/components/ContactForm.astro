---
import { siteConfig } from "../data/siteConfig";
---

<form id="contact-form" class="space-y-6">
  <input type="hidden" name="access_key" value={siteConfig.web3formsKey} />
  <input type="hidden" name="subject" value="New inquiry from techhound.ai" />
  <input type="checkbox" name="botcheck" class="hidden" />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="name" class="block text-sm font-medium mb-2">Name *</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="w-full px-4 py-3 rounded-lg border border-border-light dark:border-border-dark bg-white dark:bg-surface-dark text-[#1A1A1A] dark:text-[#F0F0F0] focus:outline-none focus:ring-2 focus:ring-gold dark:focus:ring-gold-light transition-colors"
        placeholder="Your name"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium mb-2">Email *</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-4 py-3 rounded-lg border border-border-light dark:border-border-dark bg-white dark:bg-surface-dark text-[#1A1A1A] dark:text-[#F0F0F0] focus:outline-none focus:ring-2 focus:ring-gold dark:focus:ring-gold-light transition-colors"
        placeholder="your@email.com"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="phone" class="block text-sm font-medium mb-2">Phone</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        class="w-full px-4 py-3 rounded-lg border border-border-light dark:border-border-dark bg-white dark:bg-surface-dark text-[#1A1A1A] dark:text-[#F0F0F0] focus:outline-none focus:ring-2 focus:ring-gold dark:focus:ring-gold-light transition-colors"
        placeholder="(412) 555-0123"
      />
    </div>
    <div>
      <label for="company" class="block text-sm font-medium mb-2">Company</label>
      <input
        type="text"
        id="company"
        name="company"
        class="w-full px-4 py-3 rounded-lg border border-border-light dark:border-border-dark bg-white dark:bg-surface-dark text-[#1A1A1A] dark:text-[#F0F0F0] focus:outline-none focus:ring-2 focus:ring-gold dark:focus:ring-gold-light transition-colors"
        placeholder="Your business name"
      />
    </div>
  </div>

  <div>
    <label for="service" class="block text-sm font-medium mb-2">What can we help with?</label>
    <select
      id="service"
      name="service"
      class="w-full px-4 py-3 rounded-lg border border-border-light dark:border-border-dark bg-white dark:bg-surface-dark text-[#1A1A1A] dark:text-[#F0F0F0] focus:outline-none focus:ring-2 focus:ring-gold dark:focus:ring-gold-light transition-colors"
    >
      <option value="">Select a service</option>
      <option value="Web Development">Web Development</option>
      <option value="Mobile App">Mobile App Development</option>
      <option value="Automations">Custom Business Automations</option>
      <option value="SEO/AEO">SEO & AEO</option>
      <option value="Other">Other</option>
    </select>
  </div>

  <div>
    <label for="message" class="block text-sm font-medium mb-2">Message *</label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      class="w-full px-4 py-3 rounded-lg border border-border-light dark:border-border-dark bg-white dark:bg-surface-dark text-[#1A1A1A] dark:text-[#F0F0F0] focus:outline-none focus:ring-2 focus:ring-gold dark:focus:ring-gold-light transition-colors resize-vertical"
      placeholder="Tell us about your project or what you need help with..."
    ></textarea>
  </div>

  <button type="submit" class="btn-primary w-full sm:w-auto">
    Send Message
  </button>

  <div id="form-status" class="hidden"></div>
</form>

<script>
  function initContactForm() {
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const status = document.getElementById("form-status");
    if (!form || !status) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn.textContent;
      submitBtn.textContent = "Sending...";
      submitBtn.disabled = true;

      try {
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: JSON.stringify(Object.fromEntries(new FormData(form))),
        });

        const result = await response.json();

        if (result.success) {
          status.className = "p-4 rounded-lg bg-green-50 dark:bg-green-900/20 text-green-800 dark:text-green-300 text-sm";
          status.textContent = "Thanks for reaching out! We'll get back to you within 24 hours.";
          form.reset();
        } else {
          throw new Error(result.message || "Something went wrong");
        }
      } catch {
        status.className = "p-4 rounded-lg bg-red-50 dark:bg-red-900/20 text-red-800 dark:text-red-300 text-sm";
        status.textContent = "Something went wrong. Please try again or email us directly.";
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    });
  }

  initContactForm();
  document.addEventListener("astro:after-swap", initContactForm);
</script>
