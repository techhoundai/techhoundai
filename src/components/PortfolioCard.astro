---
interface Props {
  title: string;
  description: string;
  url: string;
  image: string;
  tags: string[];
}

const { title, description, url, image, tags } = Astro.props;
---

<div class="card overflow-hidden group">
  <div class="relative overflow-hidden aspect-video">
    <img
      src={image}
      alt={`${title} project screenshot`}
      class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </div>
  <div class="p-6">
    <h2 class="text-xl font-heading font-semibold mb-2">{title}</h2>
    <p class="text-secondary text-sm leading-relaxed mb-4">{description}</p>
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map((tag) => (
        <span class="text-xs px-2 py-1 rounded-full bg-gold/10 text-gold dark:bg-gold/20 dark:text-gold font-medium">
          {tag}
        </span>
      ))}
    </div>
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 text-sm font-medium text-gold hover:underline"
    >
      View Site
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  </div>
</div>
