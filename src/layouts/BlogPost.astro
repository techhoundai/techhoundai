---
import BaseLayout from "./BaseLayout.astro";
import { siteConfig } from "../data/siteConfig";

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  image?: string;
  tags?: string[];
}

const { title, description, date, author, image, tags } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const articleMeta = {
  publishedTime: date.toISOString(),
  author,
  tags,
};
---

<BaseLayout title={title} description={description} image={image} type="article" article={articleMeta}>
  <article class="section-padding">
    <div class="container-default max-w-3xl">
      {image && (
        <div class="rounded-xl overflow-hidden mb-8 aspect-video">
          <img
            src={image}
            alt={title}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      )}

      <header class="mb-10">
        <div class="flex items-center gap-3 text-sm text-secondary mb-4">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          <span>by {author}</span>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-heading font-bold leading-tight mb-4">
          {title}
        </h1>
        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="text-xs px-2 py-1 rounded-full bg-gold/10 text-gold dark:bg-gold-light/10 dark:text-gold-light font-medium">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="prose prose-lg dark:prose-invert max-w-none
        prose-headings:font-heading prose-headings:font-semibold
        prose-a:text-gold dark:prose-a:text-gold-light prose-a:no-underline hover:prose-a:underline
        prose-img:rounded-xl
        prose-p:leading-relaxed prose-p:text-[#4A4A4A] dark:prose-p:text-[#C0C0C0]
        prose-li:text-[#4A4A4A] dark:prose-li:text-[#C0C0C0]
        prose-strong:text-[#1A1A1A] dark:prose-strong:text-[#F0F0F0]
        prose-blockquote:border-gold dark:prose-blockquote:border-gold-light
        prose-code:text-gold dark:prose-code:text-gold-light
      ">
        <slot />
      </div>
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: title,
    description: description,
    image: image ? new URL(image, siteConfig.url).href : undefined,
    datePublished: date.toISOString(),
    author: {
      "@type": "Person",
      name: author,
    },
    publisher: {
      "@type": "Organization",
      name: siteConfig.name,
      url: siteConfig.url,
    },
  })} />
</BaseLayout>
