---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Blog"
  description="Insights on web development, SEO, AI Engine Optimization, and building better software. From the TechHound team."
>
  <section class="px-4 py-10 md:py-14 sm:px-6 lg:px-8 bg-[#FAFAF8] dark:bg-[#111111]">
    <div class="container-default text-center">
      <h1 class="text-4xl sm:text-5xl font-heading font-bold mb-4">Blog</h1>
      <p class="text-secondary text-lg max-w-2xl mx-auto">
        Thoughts on software, business, and the changing tech landscape. Written by the TechHound team.
      </p>
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="section-padding">
    <div class="container-default">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
              image={post.data.image}
              tags={post.data.tags}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-secondary text-lg">Posts coming soon. Check back shortly.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
