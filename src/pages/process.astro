---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProcessStepComponent from "../components/ProcessStep.astro";
import CTABanner from "../components/CTABanner.astro";
import { processSteps } from "../data/process";
---

<BaseLayout
  title="Process & Pricing"
  description="See how TechHound works and what it costs. From discovery call to launch, our process is simple, transparent, and built around your needs."
>
  <section class="px-4 py-10 md:py-14 sm:px-6 lg:px-8 bg-[#FAFAF8] dark:bg-[#111111]">
    <div class="container-default text-center">
      <h1 class="text-4xl sm:text-5xl font-heading font-bold mb-4">Process & Pricing</h1>
      <p class="text-secondary text-lg max-w-2xl mx-auto">
        No mystery. No surprises. Here's exactly how we work and what it costs.
      </p>
    </div>
  </section>

  <!-- Process Steps -->
  <section class="section-padding">
    <div class="container-default max-w-2xl">
      <h2 class="text-3xl font-heading font-bold mb-10 text-center">How We Work</h2>
      {processSteps.map((step, index) => (
        <ProcessStepComponent
          number={step.number}
          title={step.title}
          description={step.description}
          isLast={index === processSteps.length - 1}
        />
      ))}
    </div>
  </section>

  <!-- Pricing Tiers -->
  <section class="section-padding bg-[#FAFAF8] dark:bg-[#111111]">
    <div class="container-default">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold mb-4 text-center">Pricing</h2>
      <p class="text-secondary text-center max-w-2xl mx-auto mb-12">
        Honest pricing that reflects what software actually costs to build today. No surprises, no hidden fees.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">

        <!-- Static Website -->
        <div class="card p-8 flex flex-col">
          <h3 class="text-sm font-semibold text-gold uppercase tracking-wide mb-2">Starting at</h3>
          <div class="mb-4">
            <span class="text-4xl font-heading font-bold">$2,000</span>
          </div>
          <h4 class="text-xl font-heading font-semibold mb-3">Static Website</h4>
          <p class="text-secondary text-sm leading-relaxed mb-6">
            A professionally designed, fast-loading marketing site that looks great on every device.
          </p>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>Custom design and development</span>
            </li>
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>Mobile responsive</span>
            </li>
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>SEO fundamentals</span>
            </li>
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>Fast hosting setup</span>
            </li>
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>Contact form integration</span>
            </li>
          </ul>
          <a href="/contact" class="btn-primary text-center">Get Started</a>
        </div>

        <!-- Dynamic Website / Web App -->
        <div class="card p-8 flex flex-col border-gold/40 dark:border-gold/30 ring-1 ring-gold/20">
          <h3 class="text-sm font-semibold text-gold uppercase tracking-wide mb-2">Starting at</h3>
          <div class="mb-4">
            <span class="text-4xl font-heading font-bold">$5,000</span>
          </div>
          <h4 class="text-xl font-heading font-semibold mb-3">Dynamic Website</h4>
          <p class="text-secondary text-sm leading-relaxed mb-6">
            Web applications with user accounts, databases, real-time content, booking systems, or member portals.
          </p>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>Everything in Static, plus:</span>
            </li>
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>User authentication</span>
            </li>
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>Database and backend</span>
            </li>
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>Admin dashboard</span>
            </li>
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>API integrations</span>
            </li>
          </ul>
          <a href="/contact" class="btn-primary text-center">Get a Quote</a>
        </div>

        <!-- Custom -->
        <div class="card p-8 flex flex-col">
          <h3 class="text-sm font-semibold text-gold uppercase tracking-wide mb-2">Custom</h3>
          <div class="mb-4">
            <span class="text-4xl font-heading font-bold">Let's Talk</span>
          </div>
          <h4 class="text-xl font-heading font-semibold mb-3">Apps & Automations</h4>
          <p class="text-secondary text-sm leading-relaxed mb-6">
            Mobile apps, custom automations, platform integrations, and ongoing maintenance plans.
          </p>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>Mobile apps (iOS & Android)</span>
            </li>
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>Workflow automations</span>
            </li>
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>SEO & AEO services</span>
            </li>
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>Ongoing maintenance</span>
            </li>
            <li class="flex items-start gap-2 text-sm">
              <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>Platform support</span>
            </li>
          </ul>
          <a href="/contact" class="btn-primary text-center">Schedule a Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- How We Price -->
  <section class="section-padding">
    <div class="container-default max-w-3xl">
      <h2 class="text-3xl font-heading font-bold mb-6 text-center">How We Price Projects</h2>
      <div class="space-y-4 text-secondary leading-relaxed">
        <p>
          Every project gets a fixed price before we start. We don't do hourly billing. Once we agree on scope, that's what you pay. No surprises.
        </p>
        <p>
          Our prices are lower than most agencies because we use modern tools, including AI, to work more efficiently. We pass those savings on to you. The quality doesn't change. The overhead does.
        </p>
        <p>
          For ongoing work like maintenance plans, SEO, or platform support, we offer monthly retainer packages based on the scope of work involved. We'll put together a plan that fits your budget and your needs.
        </p>
        <p>
          Not sure where your project falls? That's what the discovery call is for. It's free, and we'll give you an honest assessment of what it would take.
        </p>
      </div>
    </div>
  </section>

  <CTABanner
    title="Want a quote for your project?"
    subtitle="Every conversation starts with a free discovery call."
    buttonLabel="Get a Quote"
  />
</BaseLayout>
