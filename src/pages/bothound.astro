---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTABanner from "../components/CTABanner.astro";
---

<BaseLayout
  title="BotHound"
  description="BotHound is an AI-powered automation platform built by TechHound. Helping small businesses adopt AI into their daily workflows."
>
  <!-- Hero -->
  <section class="relative min-h-[60vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-[#0A0A0A]"></div>
    <div class="relative container-default section-padding w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block text-sm font-medium text-gold uppercase tracking-wide mb-4">A TechHound Product</span>
          <h1 class="text-4xl sm:text-5xl font-heading font-bold text-white leading-tight mb-6">
            BotHound
          </h1>
          <p class="text-lg text-[#C0C0C0] leading-relaxed mb-4">
            AI-powered automation for small businesses. Build custom bot workflows, schedule automated runs, and let AI handle the repetitive stuff so you can focus on your business.
          </p>
          <p class="text-[#999] leading-relaxed mb-8">
            No coding required. No technical team needed. Just tell BotHound what you need done and it takes care of the rest.
          </p>
          <a
            href="https://bothound.ai"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary text-lg px-8 py-4"
          >
            Try BotHound
          </a>
        </div>
        <div class="rounded-xl overflow-hidden shadow-2xl border border-[#1E1E1E]">
          <img
            src="/images/bothound1.png"
            alt="BotHound bot builder interface showing task pipelines and run history"
            class="w-full"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section-padding bg-[#FAFAF8] dark:bg-[#111111]">
    <div class="container-default">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-heading font-bold mb-4">What BotHound Does</h2>
        <p class="text-secondary max-w-2xl mx-auto">
          BotHound makes AI practical for businesses that don't have technical teams.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card p-6 text-center">
          <div class="w-14 h-14 rounded-full bg-gold/10 dark:bg-gold/20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-semibold mb-2">Bot Builder</h3>
          <p class="text-secondary text-sm leading-relaxed">
            Create multi-stage task pipelines that handle complex workflows. Set up your bot once and let it run on its own.
          </p>
        </div>
        <div class="card p-6 text-center">
          <div class="w-14 h-14 rounded-full bg-gold/10 dark:bg-gold/20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-semibold mb-2">Scheduled Runs</h3>
          <p class="text-secondary text-sm leading-relaxed">
            Schedule your bots to run on any cadence. Daily reports, weekly summaries, hourly checks. Whatever your business needs.
          </p>
        </div>
        <div class="card p-6 text-center">
          <div class="w-14 h-14 rounded-full bg-gold/10 dark:bg-gold/20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-semibold mb-2">Run History</h3>
          <p class="text-secondary text-sm leading-relaxed">
            Full visibility into every run. See what happened, when, and what the output was. No black boxes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshot -->
  <section class="section-padding">
    <div class="container-default">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="rounded-xl overflow-hidden shadow-lg border border-[#E8E4DC] dark:border-[#1E1E1E]">
          <img
            src="/images/bothound2.png"
            alt="BotHound completed run detail view showing run summary and task outputs"
            class="w-full"
            loading="lazy"
          />
        </div>
        <div>
          <h2 class="text-3xl font-heading font-bold mb-4">Built by TechHound</h2>
          <p class="text-secondary leading-relaxed mb-4">
            BotHound isn't just a product we sell. It's a product we built from scratch. It's proof that TechHound can take a complex technical idea and turn it into a polished, working product.
          </p>
          <p class="text-secondary leading-relaxed mb-6">
            When you hire TechHound, you're working with the same team that designed, developed, and shipped BotHound. We know how to build real products because we do it ourselves.
          </p>
          <a
            href="https://bothound.ai"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline"
          >
            Visit BotHound.ai
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    title="Need a custom automation?"
    subtitle="We build automation solutions for businesses of all sizes."
    buttonLabel="Talk to Us"
  />
</BaseLayout>
