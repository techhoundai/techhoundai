---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTABanner from "../../components/CTABanner.astro";
import { services } from "../../data/services";
import { siteConfig } from "../../data/siteConfig";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const paragraphs = service.longDescription.split("\n\n").filter(Boolean);
---

<BaseLayout
  title={service.title}
  description={service.description}
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-[#0A0A0A]"></div>
    <div class="relative container-default px-4 py-16 md:py-24 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <a href="/services/" class="inline-flex items-center gap-1 text-sm text-gold dark:text-gold-light hover:underline mb-6">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          All Services
        </a>
        <h1 class="text-4xl sm:text-5xl font-heading font-bold text-white leading-tight mb-6">
          {service.title}
        </h1>
        <p class="text-lg text-[#C0C0C0] leading-relaxed max-w-2xl">
          {service.description}
        </p>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="section-padding bg-[#FAFAF8] dark:bg-[#111111]">
    <div class="container-default">
      <h2 class="text-2xl sm:text-3xl font-heading font-bold mb-8">What's Included</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl">
        {service.items.map((item) => (
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-secondary">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Long Description -->
  <section class="section-padding">
    <div class="container-default max-w-3xl">
      <div class="space-y-6 text-secondary leading-relaxed text-lg">
        {paragraphs.map((p) => (
          <p>{p}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  {service.faq.length > 0 && (
    <section class="section-padding bg-[#FAFAF8] dark:bg-[#111111]">
      <div class="container-default max-w-3xl">
        <h2 class="text-2xl sm:text-3xl font-heading font-bold mb-8">Frequently Asked Questions</h2>
        <div class="space-y-6">
          {service.faq.map((item) => (
            <div class="card p-6">
              <h3 class="text-lg font-heading font-semibold mb-3">{item.question}</h3>
              <p class="text-secondary leading-relaxed">{item.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTABanner
    title="Ready to get started?"
    subtitle="Tell us about your project and we'll give you an honest assessment."
  />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    name: service.title,
    description: service.description,
    url: `${siteConfig.url}/services/${service.slug}/`,
    provider: {
      "@id": `${siteConfig.url}/#organization`,
    },
    areaServed: {
      "@type": "Country",
      name: "United States",
    },
  })} />

  {service.faq.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: service.faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    })} />
  )}
</BaseLayout>
