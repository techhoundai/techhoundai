---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import CTABanner from "../../components/CTABanner.astro";
import { services } from "../../data/services";
import { siteConfig } from "../../data/siteConfig";
---

<BaseLayout
  title="Services"
  description="Web development, AI agents, automations, lead generation, and more. TechHound handles the tech so you can handle your business."
>
  <section class="px-4 py-10 md:py-14 sm:px-6 lg:px-8 bg-[#FAFAF8] dark:bg-[#111111]">
    <div class="container-default text-center">
      <h1 class="text-4xl sm:text-5xl font-heading font-bold mb-4">Our Services</h1>
      <p class="text-secondary text-lg max-w-2xl mx-auto">
        We're basically your outsourced tech department. If it involves technology, we can build it, automate it, or manage it for you.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="section-padding">
    <div class="container-default">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <a href={`/services/${service.slug}/`} class="block">
            <ServiceCard
              title={service.title}
              description={service.description}
              icon={service.icon}
              items={service.items}
              headingLevel="h2"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: services.map((service, i) => ({
      "@type": "ListItem",
      position: i + 1,
      item: {
        "@type": "Service",
        name: service.title,
        description: service.description,
        url: `${siteConfig.url}/services/${service.slug}/`,
        provider: { "@id": `${siteConfig.url}/#organization` },
        areaServed: {
          "@type": "Country",
          name: "United States",
        },
      },
    })),
  })} />
</BaseLayout>
