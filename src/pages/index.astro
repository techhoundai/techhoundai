---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import Testimonial from "../components/Testimonial.astro";
import CTABanner from "../components/CTABanner.astro";
import { services } from "../data/services";
import { testimonials } from "../data/portfolio";
import pittImage from "../assets/images/pitt.png";
---

<BaseLayout
  title="Home"
  description="TechHound builds websites, AI agents, automations, and data tools for businesses. Based in Pittsburgh, working everywhere."
>
  <Hero
    title="Unleash Your Business."
    subtitle="Websites, apps, AI agents, automations, lead generation. We handle the tech side of your business so you don't have to. Based in Pittsburgh, working everywhere."
    cta={{ label: "Schedule a Consultation", href: "/contact/" }}
    backgroundImage={pittImage}
  />

  <!-- Services Overview -->
  <section class="section-padding bg-[#FAFAF8] dark:bg-[#111111]">
    <div class="container-default">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-heading font-bold mb-4">What We Do For You</h2>
        <p class="text-secondary max-w-2xl mx-auto">
          We're basically your outsourced tech department. If it involves technology, we can probably build it, automate it, or fix it.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <ServiceCard
            title={service.title}
            description={service.description}
            icon={service.icon}
            compact
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Why TechHound -->
  <section class="relative section-padding overflow-hidden">
    <div class="absolute inset-0 bg-[#0A0A0A]"></div>
    <div class="relative container-default">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-heading font-bold text-white mb-6">Your Business's Best Friend</h2>
        <p class="text-lg text-[#C0C0C0] leading-relaxed">
          You shouldn't need to become a tech expert just to grow your business. That's our job.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-gold/20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-semibold text-white mb-2">Your Full Tech Team</h3>
          <p class="text-[#999] text-sm leading-relaxed">
            Websites, apps, AI, automations, data. One team handles all of it. You make one call, not five.
          </p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-gold/20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-semibold text-white mb-2">Serious Experience</h3>
          <p class="text-[#999] text-sm leading-relaxed">
            Our team has built software for Fortune 500 companies and federal agencies. That experience shows up in the work we do for you.
          </p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-full bg-gold/20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-semibold text-white mb-2">Fair, Modern Pricing</h3>
          <p class="text-[#999] text-sm leading-relaxed">
            AI has changed how software gets built. We use it every day, and we pass those savings on to you.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  {testimonials.filter((t) => t.featured).length > 0 && (
    <section class="section-padding">
      <div class="container-default">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-heading font-bold mb-4">What Our Clients Say</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          {testimonials
            .filter((t) => t.featured)
            .map((t) => (
              <Testimonial quote={t.quote} name={t.name} company={t.company} />
            ))}
        </div>
        <div class="text-center mt-8">
          <a href="/portfolio/" class="text-gold dark:text-gold-light font-medium hover:underline">
            See our work &rarr;
          </a>
        </div>
      </div>
    </section>
  )}

  <CTABanner />
</BaseLayout>
